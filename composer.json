{
    "require": {
        "flightphp/core": "^3.0",
        "igorescobar/jquery-mask-plugin": "^1.14",
        "mpdf/mpdf": "^8.2",
        "nesbot/carbon": "^2.72",
        "phpoffice/phpspreadsheet": "1.29",
        "spipu/html2pdf": "*",
        "twbs/bootstrap-icons": "^1.10",
        "verot/class.upload.php": "^2.1",
        "vlucas/phpdotenv": "^5.3"
    },
    "autoload": {
        "psr-4": {
             "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "7.4.33"
        }
    }
}